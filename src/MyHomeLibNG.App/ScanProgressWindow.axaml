<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MyHomeLibNG.App.ScanProgressWindow"
        Title="Library Scan Progress"
        Width="640"
        Height="560"
        MinWidth="560"
        MinHeight="480"
        Background="#FFF4F1EA"
        WindowStartupLocation="CenterOwner"
        CanResize="True">
  <Window.Resources>
    <SolidColorBrush x:Key="HeaderBrush" Color="#FF18363B" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFBF9F4" />
    <SolidColorBrush x:Key="SurfaceStrongBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FFF0ECE3" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FF2B6A69" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#FFDDEBE8" />
    <SolidColorBrush x:Key="StrokeBrush" Color="#FFE0D9CC" />
    <SolidColorBrush x:Key="TextStrongBrush" Color="#FF1F2527" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#FF5E676B" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="16,10" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="{StaticResource SurfaceStrongBrush}" />
      <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="16,10" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Padding="24,20">
      <StackPanel Spacing="6">
        <TextBlock Text="Local Library Scan" FontSize="22" FontWeight="SemiBold" Foreground="White" />
        <TextBlock Text="{Binding LibraryName}" Foreground="#D7E8E8" />
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1" Margin="22,18,22,18" HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="16">
        <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="18">
          <StackPanel Spacing="10">
            <TextBlock Text="Current archive" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}" />
            <TextBlock Text="{Binding CurrentArchive}" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
            <ProgressBar Height="10"
                         Minimum="0"
                         Maximum="{Binding ProgressMaximum}"
                         Value="{Binding ProgressValue}" />
            <TextBlock Text="{Binding ProgressLabel}" Foreground="{StaticResource TextMutedBrush}" />
            <ProgressBar Height="6" IsIndeterminate="True" IsVisible="{Binding ShowActivityBar}" />
          </StackPanel>
        </Border>

        <Border Background="{StaticResource SurfaceStrongBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="18">
          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
            <StackPanel Margin="0,0,9,6">
              <TextBlock Text="Books found" Foreground="{StaticResource TextMutedBrush}" />
              <TextBlock Text="{Binding BooksFound}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="9,0,0,6">
              <TextBlock Text="Added" Foreground="{StaticResource TextMutedBrush}" />
              <TextBlock Text="{Binding BooksAdded}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Margin="0,6,9,6">
              <TextBlock Text="Updated" Foreground="{StaticResource TextMutedBrush}" />
              <TextBlock Text="{Binding BooksUpdated}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}" />
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="9,6,0,6">
              <TextBlock Text="Skipped" Foreground="{StaticResource TextMutedBrush}" />
              <TextBlock Text="{Binding BooksSkipped}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}" />
            </StackPanel>
            <StackPanel Grid.Row="2" Margin="0,6,9,6">
              <TextBlock Text="Archives processed" Foreground="{StaticResource TextMutedBrush}" />
              <TextBlock Text="{Binding ArchivesProcessed}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}" />
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="9,6,0,6">
              <TextBlock Text="Archives total" Foreground="{StaticResource TextMutedBrush}" />
              <TextBlock Text="{Binding ArchivesTotal}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}" />
            </StackPanel>
            <StackPanel Grid.Row="3" Margin="0,6,9,0">
              <TextBlock Text="Errors" Foreground="{StaticResource TextMutedBrush}" />
              <TextBlock Text="{Binding ErrorsCount}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}" />
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.Column="1" Margin="9,6,0,0">
              <TextBlock Text="Status" Foreground="{StaticResource TextMutedBrush}" />
              <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="{StaticResource TextStrongBrush}" />
            </StackPanel>
          </Grid>
        </Border>

        <Border Background="{StaticResource SurfaceStrongBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="18">
          <StackPanel Spacing="10">
            <TextBlock Text="Recent activity" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextStrongBrush}" />
            <ItemsControl ItemsSource="{Binding RecentLogLines}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                    <TextBlock Text="{Binding .}" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1,1,1,0" Padding="22,14">
      <DockPanel LastChildFill="False">
        <TextBlock DockPanel.Dock="Left" Text="{Binding StatusMessage}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10">
          <Button Content="Cancel" Classes="secondary" Click="OnCancelClicked" IsVisible="{Binding CanCancel}" />
          <Button Content="Close" Classes="primary" Click="OnCloseClicked" IsVisible="{Binding CanClose}" />
        </StackPanel>
      </DockPanel>
    </Border>
  </Grid>
</Window>
